{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wallpaper-manager",
  "version": "0.1.0",
  "identifier": "com.keyboard.wallpaper-manager",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "wallpaper-manager",
        "width": 800,
        "height": 140,
        "transparent": true,
        "decorations": false,
        "maximized": false,
        "resizable": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/wallpaper_downloads/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../scripts/": "scripts/"
    }
  }
}