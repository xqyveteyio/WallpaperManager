{
  "applicationId": "js.neutralino.zero",
  "version": "1.0.0",
  "defaultMode": "window",
  "documentRoot": "/frontend/dist",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "nativeAllowList": [
    "app.*",
    "os.*",
    "window.*",
    "storage.*",
    "events.*",
    "filesystem.*",
    "debug.log"
  ],
  "modes": {
    "window": {
      "title": "Wallpaper Manager",
      "center": true,
      "width": 800,
      "height": 600,
      "minWidth": 400,
      "minHeight": 200,
      "icon": "/frontend/src/assets/logo.png",
      "transparent": true,
      "exitProcessOnClose": false,
      "enableInspector": false
    }
  },
  "cli": {
    "binaryName": "wallpaper-manager",
    "resourcesPath": "/frontend/dist/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/frontend/public/neutralino.js",
    "binaryVersion": "6.8.0",
    "clientVersion": "6.8.0",
    "frontendLibrary": {
      "patchFile": "/frontend/index.html",
      "devUrl": "http://localhost:8080"
    }
  }
}